      COALESCE(CREATIVE_TYPE_NM,'')||'|'||COALESCE(CM_AREA_NM,'')||'|'||COALESCE(AD_SEC_NM,'')) AS CREATIVE_DK,
  SOURCE_SYSTEM       AS SOURCE_SYSTEM,
