  EXPS_CNT AS IMPRESSION_CNT, CLICK_CNT AS CLICK_CNT, GA_CONV_MBER_CNT AS CONV_MEMBER_CNT, CONV_VU_CNT AS CONV_UNIT_CNT,
  NULL AS INBOUND_CALL_CNT, NULL AS CONV_CALL_CNT, NULL AS AD_CNT, GA_AD_COST AS AD_COST, 'GA' AS COST_TYPE,
