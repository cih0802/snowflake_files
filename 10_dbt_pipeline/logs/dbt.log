        CAST(NULLIF(NULLIF(NULLIF(TRIM(PSTMTR_RECPTN_CD), ''), 'NULL'), '-') AS VARCHAR)   as PSTMTR_RECPTN,
        FRST_REGIST_DT                                          as JOIN_DT,
        'CRM'                                    AS DW_SOURCE_SYSTEM,
    'TM_MM_FDRM_MBER_INFO'                        AS DW_SOURCE_TABLE,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ       AS DW_LOAD_TS,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ       AS DW_UPDATE_TS,
    'b1bda8f1-0267-4f8f-879a-b5e8cfb82274'                    AS DW_BATCH_ID
    from GN_DW.BRONZE_CRM.TM_MM_FDRM_MBER_INFO
