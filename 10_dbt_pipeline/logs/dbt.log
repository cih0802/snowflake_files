         NULLIF(TRIM(CM_AREA),''), NULLIF(TRIM(AD_SEC),''), 'BRONZE_AGENCY.VIDEO_AD_CMPGN_DTLS' FROM GN_DW.BRONZE_AGENCY.VIDEO_AD_CMPGN_DTLS
)
  );
