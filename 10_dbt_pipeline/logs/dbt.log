  CONV_CALL_CNT, AD_CNT, ACTL_PUR_AD_COST_KRW, '집행', 'AGENCY','BRONZE_AGENCY.VIDEO_AD_CMPGN_DTLS',CURRENT_TIMESTAMP(),CURRENT_TIMESTAMP(),NULL
