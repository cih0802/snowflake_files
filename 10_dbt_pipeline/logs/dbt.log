create or replace  temporary view GN_DW.SILVER.CRM_MEMBER_STATUS_HIST__dbt_tmp
  
   as (
    -- CRM_MEMBER_STATUS_HIST: 정기회원 상태전이 이력 SCD2 (EFFECTIVE_FROM/TO·IS_CURRENT 파생)
-- Co-authored with CoCo


select
    CAST(NULLIF(NULLIF(NULLIF(TRIM(MBER_NO), ''), 'NULL'), '-') AS VARCHAR(10))      as MBER_NO,
    SER_NO::NUMBER(10,0)                                  as SER_NO,
    CAST(NULLIF(NULLIF(NULLIF(TRIM(BF_STAT_CD), ''), 'NULL'), '-') AS VARCHAR(3))    as BF_STAT_CD,
    CAST(NULL AS VARCHAR)                                 as BF_STAT_NM,    -- CRM_CODE 적재 후 채움
    CAST(NULLIF(NULLIF(NULLIF(TRIM(CHN_STAT_CD), ''), 'NULL'), '-') AS VARCHAR(3))   as CHN_STAT_CD,
    CAST(NULL AS VARCHAR)                                 as CHN_STAT_NM,   -- CRM_CODE 적재 후 채움
    FRST_REGIST_DT                                        as EFFECTIVE_FROM,
    LEAD(FRST_REGIST_DT) OVER (
        PARTITION BY MBER_NO ORDER BY SER_NO
    )                                                     as EFFECTIVE_TO,
    (LEAD(FRST_REGIST_DT) OVER (
        PARTITION BY MBER_NO ORDER BY SER_NO
    ) IS NULL)                                            as IS_CURRENT,
    'CRM'                                                 as DW_SOURCE_SYSTEM,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ                   as DW_LOAD_TS,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ                  as DW_UPDATE_TS,
    'ceb74d5a-8a15-469a-a434-d51e756b03fb'                                as DW_BATCH_ID
from GN_DW.BRONZE_CRM.TH_MM_FDRM_MBER_STNG_DTLS
  );
