    NULL                            AS DW_BATCH_ID
FROM GN_DW.SILVER.GA4_IDENTITY g
LEFT JOIN GN_DW.SILVER.CRM_MEMBER m
    ON g.GA_MEMBER_ID = m.MEMBER_DK
