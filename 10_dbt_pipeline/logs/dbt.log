    from GN_DW.SILVER.CRM_MEMBER_DEV
),

stop as (
    select
        TRY_TO_NUMBER(TO_CHAR(TRY_TO_DATE(SPNSR_DSCNTC_DE,'YYYYMMDD'), 'YYYYMMDD')) as DATE_SK,
        MBER_NO                                             as MEMBER_DK,
