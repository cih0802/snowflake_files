        CAST(NULLIF(NULLIF(NULLIF(TRIM(REGIST_DEPT_CD), ''), 'NULL'), '-') AS VARCHAR(10)) as REGIST_DEPT_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(JOIN_PATH_CD), ''), 'NULL'), '-') AS VARCHAR(3))    as JOIN_PATH_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(HMPG_ID), ''), 'NULL'), '-') AS VARCHAR(30))        as HMPG_ID,
