create or replace  temporary view GN_DW.SILVER.CRM_MEMBER__dbt_tmp
  
   as (
    -- CRM_MEMBER: 정기(FDRM) ∪ 일시(ONCE) 회원 통합 정제 (grain=MEMBER_DK, PK=MEMBER_DK)
-- Co-authored with CoCo
-- 원천: TM_MM_FDRM_MBER_INFO ∪ TM_MM_ONCE_MBER_INFO
-- 정제: 타입 캐스팅 · NULL 표준화 · MEMBER_TYPE 파생 · 회원키 선행0/S접두 보존(VARCHAR)
-- ⚠️ Q6: 정기/일시 UNION 스키마 정렬(잠정). 코드→라벨(_NM)은 CRM_CODE 적재 후 채움(현재 NULL)
-- ⚠️ EMAIL/PSTMTR_RECPTN: 정기=코드(멀티값 '2,5,6'), 일시=Y/N — raw 보존(정규화는 후속)


with regular as (
    select
        CAST(NULLIF(NULLIF(NULLIF(TRIM(MBER_NO), ''), 'NULL'), '-') AS VARCHAR(10))       as MEMBER_DK,
        'FDRM'                                                 as MEMBER_TYPE,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(MBER_DIV_CD), ''), 'NULL'), '-') AS VARCHAR(3))     as MBER_DIV_CD,
        CAST(NULL AS VARCHAR)                                  as MBER_DIV_NM,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(CPR_DIV_CD), ''), 'NULL'), '-') AS VARCHAR(3))      as CPR_DIV_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(SEX), ''), 'NULL'), '-') AS VARCHAR(2))             as SEX,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(MBER_STAT_CD), ''), 'NULL'), '-') AS VARCHAR(3))    as MBER_STAT_CD,
        CAST(NULL AS VARCHAR)                                  as MBER_STAT_NM,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(CMPGN_CD), ''), 'NULL'), '-') AS VARCHAR(20))       as CMPGN_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(ACT_DEPT_CD), ''), 'NULL'), '-') AS VARCHAR(10))    as ACT_DEPT_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(REGIST_DEPT_CD), ''), 'NULL'), '-') AS VARCHAR(10)) as REGIST_DEPT_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(JOIN_PATH_CD), ''), 'NULL'), '-') AS VARCHAR(3))    as JOIN_PATH_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(HMPG_ID), ''), 'NULL'), '-') AS VARCHAR(30))        as HMPG_ID,
        CAST(NULL AS VARCHAR(200))                             as ENTRPS_NM,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(EMAIL_RECPTN_CD), ''), 'NULL'), '-') AS VARCHAR)    as EMAIL_RECPTN,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(PSTMTR_RECPTN_CD), ''), 'NULL'), '-') AS VARCHAR)   as PSTMTR_RECPTN,
        TRY_TO_TIMESTAMP_NTZ(FRST_REGIST_DT)                   as JOIN_DT,
        'CRM'                                    AS DW_SOURCE_SYSTEM,
    'TM_MM_FDRM_MBER_INFO'                        AS DW_SOURCE_TABLE,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ       AS DW_LOAD_TS,
    _BATCH_ID::VARCHAR                 AS DW_BATCH_ID
    from GN_DW.BRONZE_CRM.TM_MM_FDRM_MBER_INFO
),

once as (
    select
        CAST(NULLIF(NULLIF(NULLIF(TRIM(ONCE_MBER_NO), ''), 'NULL'), '-') AS VARCHAR(10))   as MEMBER_DK,
        'ONCE'                                                 as MEMBER_TYPE,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(MBER_DIV_CD), ''), 'NULL'), '-') AS VARCHAR(3))     as MBER_DIV_CD,
        CAST(NULL AS VARCHAR)                                  as MBER_DIV_NM,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(CPR_DIV_CD), ''), 'NULL'), '-') AS VARCHAR(3))      as CPR_DIV_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(SEX), ''), 'NULL'), '-') AS VARCHAR(2))             as SEX,
        CAST(NULL AS VARCHAR(3))                               as MBER_STAT_CD,
        CAST(NULL AS VARCHAR)                                  as MBER_STAT_NM,
        CAST(NULL AS VARCHAR(20))                              as CMPGN_CD,
        CAST(NULL AS VARCHAR(10))                              as ACT_DEPT_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(REGIST_DEPT_CD), ''), 'NULL'), '-') AS VARCHAR(10)) as REGIST_DEPT_CD,
        CAST(NULL AS VARCHAR(3))                               as JOIN_PATH_CD,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(HMPG_ID), ''), 'NULL'), '-') AS VARCHAR(30))        as HMPG_ID,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(ENTRPS_NM), ''), 'NULL'), '-') AS VARCHAR(200))     as ENTRPS_NM,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(EMAIL_RECPTN_YN), ''), 'NULL'), '-') AS VARCHAR)    as EMAIL_RECPTN,
        CAST(NULLIF(NULLIF(NULLIF(TRIM(PSTMTR_RECPTN_YN), ''), 'NULL'), '-') AS VARCHAR)   as PSTMTR_RECPTN,
        TRY_TO_TIMESTAMP_NTZ(FRST_REGIST_DT)                   as JOIN_DT,
        'CRM'                                    AS DW_SOURCE_SYSTEM,
    'TM_MM_ONCE_MBER_INFO'                        AS DW_SOURCE_TABLE,
    CURRENT_TIMESTAMP()::TIMESTAMP_NTZ       AS DW_LOAD_TS,
    _BATCH_ID::VARCHAR                 AS DW_BATCH_ID
    from GN_DW.BRONZE_CRM.TM_MM_ONCE_MBER_INFO
)

select * from regular
union all
select * from once
  );
