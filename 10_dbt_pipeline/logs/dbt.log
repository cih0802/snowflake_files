  'CRM','BRONZE_CRM.TM_PM_DNTN_DTLS', CURRENT_TIMESTAMP(), CURRENT_TIMESTAMP(), NULL
FROM GN_DW.BRONZE_CRM.TM_PM_DNTN_DTLS WHERE DNTN_KEY IS NOT NULL
  );
