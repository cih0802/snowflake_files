  NULL                             AS DW_BATCH_ID
FROM GN_DW.BRONZE_CRM.TM_PM_MBRFEE_ACMSLT WHERE MBRFEE_KEY IS NOT NULL
UNION ALL
SELECT
  'DNTN_'||DNTN_KEY, '기부금', NULLIF(TRIM(ONCE_MBER_NO),''), NULLIF(TRIM(SPNSR_BSNS_ID),''), NULL,
