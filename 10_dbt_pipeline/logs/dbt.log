FROM GN_DW.BRONZE_AGENCY.DGT_AD_CMPGN_DTLS
UNION ALL
SELECT 'REBROADCAST', DATE, YEAR(DATE), MONTH(DATE),
  NULL, NULL, NULLIF(TRIM(CHNNL_CMPNY),''), NULL,
